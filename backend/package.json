{
  "name": "psicologia-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node test/appointments.logic.test.js && node test/clinical-notes.logic.test.js && node test/patient-intake.logic.test.js",
    "db:schema": "node scripts/run-sql-file.js sql/schema.sql",
    "db:seed": "node scripts/run-sql-file.js sql/seed.sql",
    "db:init": "npm run db:schema && npm run db:seed",
    "db:normalize-appointments": "node scripts/normalize-appointment-times.js",
    "db:normalize-future-clinical-notes": "node scripts/normalize-future-clinical-notes.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
